# Обязательно
BOT_TOKEN=your_token_here

# Instagram через Apify (опционально)
APIFY_TOKEN=
APIFY_INSTAGRAM_ACTOR=elis~instagram-downloader-api

# LLM (опционально, по умолчанию выключен)
LLM_ENABLED=false
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=dummy
LLM_MODEL=gemma4:e4b
LLM_COOLDOWN_SECONDS=5
LLM_WEB_SEARCH_ENABLED=false
LLM_WEB_SEARCH_MAX_RESULTS=5
LLM_TIMEZONE=Asia/Almaty

# Cobalt — бесплатный primary-downloader для YouTube/Reddit (yt-dlp остаётся fallback)
COBALT_ENABLED=true
COBALT_API_URL=https://capi.3kh0.net

# Web / Telegram Mini App
WEB_ENABLED=true          # поднимать ли FastAPI сервер
WEB_PORT=8080             # порт FastAPI
USE_CLOUDFLARE=true       # авто-туннель через cloudflared (trycloudflare.com)
