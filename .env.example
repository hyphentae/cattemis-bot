# Обязательно
BOT_TOKEN=your_token_here

# Instagram через Apify (опционально)
APIFY_TOKEN=
APIFY_INSTAGRAM_ACTOR=elis~instagram-downloader-api
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=linux:cattemis-bot:v1.0 (by /u/YOUR_REDDIT_USERNAME)

# Донаты (опционально; Telegram Stars работают без дополнительных ключей)
KOFI_URL=https://ko-fi.com/YOUR_USERNAME

# LLM (опционально, по умолчанию выключен)
LLM_ENABLED=false
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=dummy
LLM_MODEL=gemma4:e4b
LLM_COOLDOWN_SECONDS=5
LLM_REQUEST_TIMEOUT_SECONDS=120
LLM_WEB_SEARCH_ENABLED=false
LLM_WEB_SEARCH_MAX_RESULTS=5
LLM_TIMEZONE=Asia/Almaty

# Cobalt — бесплатный primary-downloader для YouTube/Reddit (yt-dlp остаётся fallback)
COBALT_ENABLED=true
COBALT_API_URL=https://capi.3kh0.net

# Лимиты загрузки медиа (Telegram отправляет альбомами по 10)
MAX_MEDIA_ITEMS=50

# Web / Telegram Mini App
WEB_ENABLED=true          # включить Mini App
WEB_PORT=8080             # порт Mini App сервера
USE_CLOUDFLARE=true       # авто-туннель через cloudflared (trycloudflare.com)
