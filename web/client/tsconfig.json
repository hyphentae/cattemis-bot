{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowImportingTsExtensions": true,
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["*.ts", "*.d.ts"]
}
